{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "india",
	"compatibility_date": "2025-04-04",
	"compatibility_flags": [
        "nodejs_compat"
    ],
	"main": "./workers/app.ts",
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "india",
			"database_id": "3be37161-6f61-4d8e-82ab-f09e81e11536",
		}
	]
}